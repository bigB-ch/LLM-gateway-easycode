# LLM Gateway Production Configuration
# IMPORTANT: Fill in all placeholders below before deploying

# Domain (required for SSL — use domain if available, otherwise IP)
DOMAIN=easycode.uno

# PostgreSQL
POSTGRES_DB=llm_gateway
POSTGRES_USER=gateway
POSTGRES_PASSWORD=SecureDbPass2026

# Redis
REDIS_URL=redis://redis:6379

# JWT (generated: secrets.token_hex(32))
JWT_SECRET=61965289531c527babf8d374179277bd7a82003ca1ecba7f7495a9ff30e2968b

# Email (SMTP for verification codes — fill with real SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=noreply@example.com

# AI Provider (REQUIRED — fill in your OpenAI API key)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# CORS origins (use your actual domain or IP)
CORS_ORIGINS=https://easycode.uno

# Admin initial user
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database — set to "false" after first run to use Alembic migrations
DB_AUTO_CREATE=true
