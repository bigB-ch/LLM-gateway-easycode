# Domain
DOMAIN=localhost

# PostgreSQL
POSTGRES_DB=llm_gateway
POSTGRES_USER=gateway
POSTGRES_PASSWORD=change-me-in-production
# Admin service connects via this URL (built from POSTGRES_* vars in docker-compose)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Redis (single instance for dev)
REDIS_URL=redis://redis:6379

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=change-me-use-openssl-rand-hex-64

# Email (SMTP for verification codes)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=noreply@example.com

# AI Provider (OpenAI API key required)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# CORS origins (comma-separated, must include your frontend domain)
CORS_ORIGINS=https://your-domain.com

# Admin initial user
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database auto-create (set to "false" in production; use Alembic migrations instead)
DB_AUTO_CREATE=true

# Grafana (optional)
GRAFANA_PASSWORD=admin
